.product-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 16rpx;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  background: #F0F0F0;
  flex-shrink: 0;
}

.body {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.foot {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 8rpx;
}

.price {
  color: var(--brand-color);
  font-weight: 700;
}
.price .symbol { font-size: 24rpx; margin-right: 2rpx; }
.price .value  { font-size: 36rpx; }

.right {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: right;
}
.stock.soldout      { color: var(--text-placeholder); }
.stock.unavailable  { color: var(--text-placeholder); }
.participants       { margin-left: 4rpx; }
