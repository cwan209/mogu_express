<view class="container">
  <view class="tabs">
    <view class="tab {{tab === 'all' ? 'active' : ''}}" data-t="all" bindtap="onTab">全部</view>
    <view class="tab {{tab === 'paid' ? 'active' : ''}}" data-t="paid" bindtap="onTab">已支付</view>
    <view class="tab {{tab === 'shipped' ? 'active' : ''}}" data-t="shipped" bindtap="onTab">已发货</view>
    <view class="tab {{tab === 'completed' ? 'active' : ''}}" data-t="completed" bindtap="onTab">已完成</view>
  </view>

  <block wx:if="{{filtered.length > 0}}">
    <view
      class="order-card"
      wx:for="{{filtered}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onTapOrder"
    >
      <view class="head">
        <text class="no">{{item.orderNo}}</text>
        <text class="status status-{{item.status}}">{{statusLabel[item.status]}}</text>
      </view>
      <view class="items">
        <image
          wx:for="{{item.items}}"
          wx:key="productId"
          wx:for-item="it"
          src="{{it.coverFileId}}"
          class="thumb"
          mode="aspectFill"
        />
      </view>
      <view class="foot">
        <text class="count">共 {{item.items.length}} 件</text>
        <text class="amount">¥{{amountMap[item._id]}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:else>
    <text>{{tab === 'all' ? '还没有订单' : '该状态下没有订单'}}</text>
  </view>
</view>
