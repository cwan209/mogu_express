/* pages/profile/index.wxss */
.profile-card {
  background: var(--bg-card);
  padding: 48rpx 24rpx;
  border-radius: var(--radius-md);
  text-align: center;
  margin-bottom: 24rpx;
}

.avatar-placeholder {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.greet {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.hint {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.foot {
  margin-top: 48rpx;
  text-align: center;
  color: var(--text-placeholder);
  font-size: 24rpx;
}
