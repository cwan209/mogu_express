page { padding-bottom: 180rpx; }

.list {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-top: 8rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.row:last-child { border-bottom: none; }

/* 自制 checkbox */
.cb-hit {
  padding: 16rpx 8rpx 16rpx 0;      /* 扩大点击热区 */
  display: flex;
  align-items: center;
}
.cb-hit.disabled .cb { opacity: 0.4; }
.cb {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CCC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  background: #fff;
  box-sizing: border-box;
}
.cb.on {
  background: var(--brand-color);
  border-color: var(--brand-color);
}
.cb.off { border-color: #DDD; background: #F5F5F5; }

.bar-left { display: flex; align-items: center; gap: 8rpx; }
.all-text { font-size: 24rpx; color: var(--text-primary); }

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background: #EEE;
}

.body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 160rpx;
  min-width: 0;
}

.title {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.meta-row {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.meta-row .bad { color: var(--error-color); margin-left: 4rpx; }

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.price { color: var(--brand-color); font-weight: 700; }
.price .sym { font-size: 22rpx; }
.price .val { font-size: 34rpx; margin-left: 2rpx; }

.space { height: 40rpx; }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 10;
}
.bar-mid { flex: 1; text-align: right; }
.total-label { color: var(--text-secondary); font-size: 24rpx; margin-right: 6rpx; }
.total-val   { color: var(--brand-color); font-size: 32rpx; font-weight: 700; }
.bar-del {
  font-size: 26rpx;
  color: var(--error-color);
  padding: 20rpx 16rpx;
  flex-shrink: 0;
}
.bar-del:active {
  opacity: 0.6;
}

.empty {
  text-align: center;
  padding: 160rpx 0 40rpx;
  color: var(--text-secondary);
}
.empty-ico { font-size: 120rpx; margin-bottom: 16rpx; }
.back-btn { margin-top: 32rpx; }
