<view class="container" wx:if="{{order}}">
  <!-- 状态头 -->
  <view class="result state-{{order.payStatus}}">
    <view class="ico">
      <text wx:if="{{order.payStatus === 'paid'}}">✓</text>
      <text wx:elif="{{order.payStatus === 'pending'}}">⏱</text>
      <text wx:elif="{{order.payStatus === 'failed'}}">✗</text>
      <text wx:else>?</text>
    </view>
    <view class="title">
      <block wx:if="{{order.payStatus === 'paid'}}">支付成功</block>
      <block wx:elif="{{order.payStatus === 'pending'}}">等待支付</block>
      <block wx:elif="{{order.payStatus === 'failed'}}">支付失败</block>
      <block wx:else>下单成功</block>
    </view>
    <view class="sub">
      <block wx:if="{{mode === 'stub' && order.payStatus !== 'paid'}}">HuePay Stub 模式 · 点下方按钮模拟支付</block>
      <block wx:elif="{{order.payStatus === 'pending'}}">检测中... ({{pollCount}}/{{maxPoll}})</block>
      <block wx:elif="{{order.payStatus === 'paid'}}">订单已支付</block>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info">
    <view class="r"><text>订单号</text><text>{{order.orderNo}}</text></view>
    <view class="r"><text>金额</text><text class="brand">¥{{amountText}}</text></view>
    <view class="r"><text>下单时间</text><text>{{createdAtText}}</text></view>
    <view class="r"><text>商品数量</text><text>{{order.items.length}} 件</text></view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <!-- Stub: 模拟支付 -->
    <t-button
      wx:if="{{mode === 'stub' && order.payStatus !== 'paid'}}"
      theme="primary"
      block
      loading="{{simulating}}"
      bind:tap="onSimulatePay"
    >{{ simulating ? '处理中...' : '模拟支付成功' }}</t-button>

    <!-- 真实 pending: 手动查询 -->
    <t-button
      wx:if="{{mode !== 'stub' && order.payStatus === 'pending'}}"
      theme="primary"
      block
      loading="{{querying}}"
      bind:tap="onQueryNow"
    >{{ querying ? '查询中...' : '我已支付,点击确认' }}</t-button>

    <t-button theme="primary" block bind:tap="onGoOrders" wx:if="{{order.payStatus === 'paid'}}">查看我的订单</t-button>
    <t-button theme="default" block bind:tap="onGoHome">继续浏览</t-button>
  </view>
</view>

<view class="loading" wx:else>加载中...</view>
