page {
  padding-bottom: 180rpx;
}

.swiper {
  width: 100%;
  height: 600rpx;
  background: #000;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
}
.swiper-img {
  width: 100%;
  height: 100%;
}

.info-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}
.price-row .symbol { color: var(--brand-color); font-size: 28rpx; font-weight: 700; }
.price-row .price  { color: var(--brand-color); font-size: 52rpx; font-weight: 700; margin-left: 4rpx; }
.price-row .part   { margin-left: 16rpx; color: var(--text-secondary); font-size: 24rpx; }

.title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  color: var(--text-primary);
}

.desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.tuan-line {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed var(--border-color);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}
.tuan-label  { color: var(--text-secondary); }
.tuan-title  {
  color: var(--brand-color);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.closed-tag {
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.stock-line {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.stock-line .soldout,
.stock-line .unavailable {
  color: var(--warning-color);
}

.detail-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.detail-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
}

.safe-bottom {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 10;
}

.bar-icons {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.bar-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  font-weight: normal;
  line-height: 1;
}
.bar-icon::after { border: none; }     /* 去掉 button 默认 1rpx 边 */
.bar-icon[hover-class] { opacity: 0.6; }
.i-ico {
  font-size: 36rpx;
  color: var(--brand-color);
  line-height: 1.2;
}
.i-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 2rpx;
}

.loading-mask, .empty {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
}
