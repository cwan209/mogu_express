.hero {
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, var(--brand-color) 0%, #F06977 100%);
  border-radius: var(--radius-lg);
  color: #fff;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

/* 骨架屏 */
.skeleton {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.sk-cover {
  width: 100%;
  height: 280rpx;
  background: #EEE;
  border-radius: var(--radius-sm);
}
.sk-line {
  height: 24rpx;
  background: #EEE;
  border-radius: 4rpx;
  margin-top: 16rpx;
}
.sk-line-w { width: 85%; }
.sk-line-n { width: 50%; }
