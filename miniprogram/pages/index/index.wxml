<view class="container">
  <view class="hero">
    <view class="hero-title">接龙团购</view>
    <view class="hero-sub">本周进行中 · 尽快接龙抢货</view>
  </view>

  <block wx:if="{{loading && !tuans.length}}">
    <view class="skeleton" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="sk-cover"></view>
      <view class="sk-line sk-line-w"></view>
      <view class="sk-line sk-line-n"></view>
    </view>
  </block>

  <block wx:elif="{{tuans.length > 0}}">
    <tuan-card
      wx:for="{{tuans}}"
      wx:key="_id"
      tuan="{{item}}"
    />
  </block>

  <view class="empty" wx:else>
    <text>暂无进行中的团</text>
  </view>
</view>
