<view class="page" wx:if="{{tuan}}">
  <!-- 团 hero -->
  <view class="tuan-hero">
    <image class="cover" src="{{tuan.coverFileId}}" mode="aspectFill" />
    <view class="tuan-body">
      <view class="title">{{tuan.title}}</view>
      <view class="status-row">
        <view wx:if="{{tuan.status === 'on_sale'}}" class="tag tag-sale">进行中</view>
        <view wx:elif="{{tuan.status === 'scheduled'}}" class="tag tag-scheduled">待开团</view>
        <view wx:elif="{{tuan.status === 'closed'}}" class="tag tag-closed">已截团</view>
        <countdown wx:if="{{tuan.status === 'on_sale'}}" target="{{tuan.endAt}}" prefix="距截止" mode="end" />
        <countdown wx:elif="{{tuan.status === 'scheduled'}}" target="{{tuan.startAt}}" prefix="距开团" mode="before" />
      </view>
      <view class="desc" wx:if="{{tuan.description}}">{{tuan.description}}</view>
      <view class="meta">
        <text>开团 {{startAtText}}</text>
        <text class="dot">·</text>
        <text>截止 {{endAtText}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-wrap">
    <t-search
      value="{{searchKeyword}}"
      placeholder="搜索团内商品"
      shape="round"
      bind:change="onSearchChange"
      bind:clear="onSearchClear"
    />
  </view>

  <!-- 搜索态:单列结果 -->
  <block wx:if="{{searchKeyword}}">
    <view class="result-hint">搜索到 {{searchResults.length}} 个结果</view>
    <view class="result-list">
      <product-card
        wx:for="{{searchResults}}"
        wx:key="_id"
        product="{{item}}"
        available="{{tuan.status === 'on_sale'}}"
      />
      <view wx:if="{{searchResults.length === 0}}" class="empty-search">没有匹配的商品</view>
    </view>
  </block>

  <!-- 正常态:双栏(hasAnySection) 或 单列(全无 section) -->
  <block wx:elif="{{hasAnySection}}">
    <view class="two-col">
      <!-- 左 sidebar -->
      <scroll-view class="side" scroll-y>
        <view
          wx:for="{{groups}}"
          wx:key="section"
          class="side-item {{activeSection === item.section ? 'active' : ''}}"
          data-section="{{item.section}}"
          bindtap="onSectionTap"
        >
          <text>{{item.section}}</text>
        </view>
      </scroll-view>

      <!-- 右商品区 -->
      <scroll-view class="main" scroll-y>
        <view class="section-title">{{activeSection}}</view>
        <product-card
          wx:for="{{activeGroupProducts}}"
          wx:key="_id"
          product="{{item}}"
          available="{{tuan.status === 'on_sale'}}"
        />
        <view class="scroll-bottom-pad"></view>
      </scroll-view>
    </view>
  </block>

  <!-- 全无 section 退化:单列 -->
  <block wx:else>
    <view class="products">
      <product-card
        wx:for="{{products}}"
        wx:key="_id"
        product="{{item}}"
        available="{{tuan.status === 'on_sale'}}"
      />
    </view>
  </block>

  <view class="bottom-spacer"></view>

  <!-- 底栏:分享 + 海报 -->
  <view class="bottom-bar">
    <button class="share-btn" open-type="share" hover-class="none" plain="true">
      <text class="i-ico">⇪</text>
      <text class="i-text">转发好友/群</text>
    </button>
    <view class="poster-btn" bindtap="onPoster">
      <text class="i-ico">🖼</text>
      <text class="i-text">生成海报</text>
    </view>
  </view>
</view>

<view class="loading-mask" wx:elif="{{loading}}">加载中...</view>
<view class="empty" wx:else>团不存在或已删除</view>
