.page {
  padding: 24rpx;
  padding-bottom: 0;
  box-sizing: border-box;
}

.tuan-hero {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.cover {
  width: 100%;
  height: 300rpx;
  display: block;
  background: #EEE;
}

.tuan-body { padding: 20rpx 24rpx; }
.title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}
.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  color: #fff;
}
.tag-sale      { background: var(--brand-color); }
.tag-scheduled { background: var(--warning-color); }
.tag-closed    { background: rgba(0, 0, 0, 0.4); }
.desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
.meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-placeholder);
}
.meta .dot { margin: 0 8rpx; }

/* 搜索栏 */
.search-wrap {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16rpx;
}

/* 搜索结果 */
.result-hint {
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 0 4rpx 16rpx;
}
.result-list .empty-search {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-placeholder);
}

/* ── 双栏布局 ── */
.two-col {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  /* 高度:窗口减去上方 hero(估 ~450rpx)和底栏(~140rpx) */
  height: calc(100vh - 640rpx);
  min-height: 800rpx;
}

.side {
  width: 180rpx;
  flex-shrink: 0;
  background: #F7F7F7;
  border-right: 1rpx solid var(--border-color);
}
.side-item {
  padding: 28rpx 16rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  border-left: 6rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  line-height: 1.3;
  word-break: break-all;
  position: relative;
}
.side-item .count {
  font-size: 20rpx;
  color: var(--text-placeholder);
}
.side-item.active {
  background: #fff;
  border-left-color: var(--brand-color);
  color: var(--brand-color);
  font-weight: 600;
}
.side-item.active .count { color: var(--brand-color); }

.main {
  flex: 1;
  padding: 0 16rpx;
}
.group {
  padding-top: 16rpx;
}
.section-anchor.section-title {
  position: sticky;
  top: 0;
  background: var(--bg-card);
  padding: 16rpx 4rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  z-index: 2;
}
.scroll-bottom-pad { height: 32rpx; }

/* 单列(退化态)*/
.products {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 16rpx;
}

/* 底栏 */
.bottom-spacer { height: 140rpx; }
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  gap: 16rpx;
  z-index: 10;
}
.share-btn,
.poster-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--brand-color);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
  border: none;
  font-weight: 500;
  box-sizing: border-box;
}
.share-btn::after { border: none; }
.poster-btn {
  background: #fff;
  color: var(--brand-color);
  border: 2rpx solid var(--brand-color);
}
.poster-btn:active,
.share-btn:active { opacity: 0.8; }
.share-btn .i-ico,
.poster-btn .i-ico { font-size: 30rpx; }

.loading-mask,
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
}

/* 团公告入口 */
.announcement-entry {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 167, 38, 0.12);
  border: 1rpx solid rgba(255, 167, 38, 0.4);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #B26900;
}
.announcement-icon { margin-right: 6rpx; }
