.status-card {
  padding: 32rpx 24rpx;
  color: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}
.status-card.status-pending_pay { background: var(--warning-color); }
.status-card.status-paid        { background: var(--success-color); }
.status-card.status-shipped     { background: #1677FF; }
.status-card.status-completed   { background: rgba(0,0,0,0.5); }
.status-card.status-cancelled   { background: var(--text-placeholder); }
.status-card.status-refunded    { background: var(--error-color); }
.status-card .s { font-size: 34rpx; font-weight: 700; display: block; }
.status-card .hint { font-size: 24rpx; opacity: 0.9; margin-top: 6rpx; display: block; }

.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card-title { font-weight: 600; margin-bottom: 16rpx; font-size: 28rpx; }
.addr-name { font-weight: 600; color: var(--text-primary); margin-bottom: 6rpx; }
.addr-body { color: var(--text-secondary); font-size: 26rpx; line-height: 1.5; }

.item { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid var(--border-color); }
.item:last-child { border-bottom: none; }
.cover { width: 120rpx; height: 120rpx; border-radius: var(--radius-sm); background: #EEE; }
.body { flex: 1; padding-left: 16rpx; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.body .t { font-size: 26rpx; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.body .row { display: flex; justify-content: space-between; font-size: 24rpx; }
.body .p { color: var(--brand-color); font-weight: 600; }
.body .q { color: var(--text-secondary); }

.line {
  display: flex; justify-content: space-between;
  font-size: 26rpx; color: var(--text-secondary); padding: 8rpx 0;
}
.line.total { margin-top: 8rpx; padding-top: 16rpx; border-top: 1rpx dashed var(--border-color); color: var(--text-primary); font-weight: 600; }
.big { color: var(--brand-color); font-size: 32rpx; }

.info-row {
  display: flex; justify-content: space-between;
  padding: 10rpx 0; font-size: 26rpx;
}
.info-row text:first-child { color: var(--text-secondary); }

.actions { margin-top: 32rpx; }
.empty { text-align: center; padding: 200rpx 0; color: var(--text-secondary); }
