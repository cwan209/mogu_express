<view class="container" wx:if="{{order}}">
  <view class="status-card status-{{order.status}}">
    <text class="s">{{statusLabel[order.status]}}</text>
    <text class="hint" wx:if="{{order.status === 'paid'}}">已支付,等待团长发货</text>
    <text class="hint" wx:elif="{{order.status === 'shipped'}}">已发货</text>
    <text class="hint" wx:elif="{{order.status === 'cancelled'}}">订单已取消</text>
  </view>

  <view class="card">
    <view class="card-title">收货信息</view>
    <view class="addr-name">{{order.shipping.recipient}} · {{order.shipping.phone}}</view>
    <view class="addr-body">
      {{order.shipping.line1}}{{order.shipping.line2 ? ', ' + order.shipping.line2 : ''}}, {{order.shipping.suburb}} {{order.shipping.state}} {{order.shipping.postcode}}
    </view>
  </view>

  <view class="card">
    <view class="card-title">商品清单</view>
    <view class="item" wx:for="{{order.items}}" wx:key="productId">
      <image class="cover" src="{{item.coverFileId}}" mode="aspectFill" />
      <view class="body">
        <view class="t">{{item.title}}</view>
        <view class="row">
          <text class="p">A$ {{priceMap[item.productId]}}</text>
          <text class="q">× {{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">金额</view>
    <view class="line"><text>商品总额</text><text>A$ {{amountText}}</text></view>
    <view class="line"><text>运费</text><text>A$ 0.00</text></view>
    <view class="line total"><text>实付</text><text class="big">A$ {{amountText}}</text></view>
  </view>

  <view class="card">
    <view class="card-title">订单信息</view>
    <view class="info-row"><text>订单号</text><text>{{order.orderNo}}</text></view>
    <view class="info-row"><text>创建时间</text><text>{{createdAtText}}</text></view>
    <view class="info-row" wx:if="{{order.paidAt}}"><text>支付时间</text><text>{{paidAtText}}</text></view>
    <view class="info-row" wx:if="{{order.remark}}"><text>备注</text><text>{{order.remark}}</text></view>
  </view>

  <view class="actions" wx:if="{{order.status === 'pending_pay'}}">
    <t-button theme="default" block bind:tap="onCancel">取消订单</t-button>
  </view>
</view>

<view class="empty" wx:elif="{{!loading}}">订单不存在</view>
