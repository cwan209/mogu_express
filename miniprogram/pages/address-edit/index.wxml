<view class="container">
  <!-- 列表模式 -->
  <block wx:if="{{screen === 'list'}}">
    <view class="list">
      <view class="row" wx:for="{{addresses}}" wx:key="_id" data-id="{{item._id}}" bindtap="onPickRow">
        <view class="body">
          <view class="head">
            <text class="name">{{item.recipient}}</text>
            <text class="phone">{{item.phone}}</text>
            <text class="tag" wx:if="{{item.isDefault}}">默认</text>
          </view>
          <view class="addr-text">{{item.state}} {{item.suburb}} {{item.line1}}{{item.line2 ? ' ' + item.line2 : ''}}  {{item.postcode}}</view>
        </view>
        <view class="right">
          <view class="ed" catchtap="onEdit" data-id="{{item._id}}">编辑</view>
        </view>
      </view>
      <view class="empty-list" wx:if="{{addresses.length === 0}}">暂无地址</view>
    </view>
    <view class="new-btn">
      <t-button theme="primary" block bind:tap="onNew">新增收货地址</t-button>
    </view>
  </block>

  <!-- 编辑模式 -->
  <block wx:else>
    <view class="form">
      <!-- 收件人 -->
      <t-cell title="收件人" bordered>
        <t-input
          slot="note"
          placeholder="请输入真实姓名"
          maxlength="20"
          value="{{form.recipient}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="recipient"
          borderless
        />
      </t-cell>
      <view class="err" wx:if="{{errors.recipient}}">{{errors.recipient}}</view>

      <!-- 手机号 -->
      <t-cell title="手机号" bordered>
        <t-input
          slot="note"
          placeholder="11 位大陆手机号"
          maxlength="13"
          value="{{form.phone}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="phone"
          borderless
          type="number"
        />
      </t-cell>
      <view class="err" wx:if="{{errors.phone}}">{{errors.phone}}</view>

      <!-- 省(picker)-->
      <picker
        mode="selector"
        range="{{stateOptions}}"
        value="{{stateIndex}}"
        bindchange="onStateChange"
      >
        <t-cell title="省/市/自治区" bordered arrow>
          <text slot="note" class="picker-value">{{form.state || '请选择'}}</text>
        </t-cell>
      </picker>
      <view class="err" wx:if="{{errors.state}}">{{errors.state}}</view>

      <!-- 市/区 -->
      <t-cell title="市/区" bordered>
        <t-input
          slot="note"
          placeholder="例:杭州市 西湖区"
          maxlength="30"
          value="{{form.suburb}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="suburb"
          borderless
        />
      </t-cell>
      <view class="err" wx:if="{{errors.suburb}}">{{errors.suburb}}</view>

      <!-- 详细地址 -->
      <t-cell title="详细地址" bordered>
        <t-input
          slot="note"
          placeholder="街道 + 门牌号"
          maxlength="60"
          value="{{form.line1}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="line1"
          borderless
        />
      </t-cell>
      <view class="err" wx:if="{{errors.line1}}">{{errors.line1}}</view>

      <!-- 门牌/单元 选填 -->
      <t-cell title="门牌/单元" bordered>
        <t-input
          slot="note"
          placeholder="选填:楼栋/单元/室号"
          maxlength="30"
          value="{{form.line2}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="line2"
          borderless
        />
      </t-cell>
      <view class="err" wx:if="{{errors.line2}}">{{errors.line2}}</view>

      <!-- 邮编 -->
      <t-cell title="邮编" bordered>
        <t-input
          slot="note"
          placeholder="6 位数字,如 310000"
          maxlength="6"
          value="{{form.postcode}}"
          bind:change="onField"
          bind:blur="onFieldBlur"
          data-k="postcode"
          borderless
          type="number"
        />
      </t-cell>
      <view class="err" wx:if="{{errors.postcode}}">{{errors.postcode}}</view>

      <!-- 设为默认 -->
      <t-cell title="设为默认">
        <t-switch slot="note" value="{{form.isDefault}}" bind:change="onToggleDefault" />
      </t-cell>
    </view>

    <view class="form-actions">
      <t-button theme="primary" block bind:tap="onSave">保存</t-button>
      <t-button theme="default" block bind:tap="onDelete" wx:if="{{form._id}}">删除</t-button>
    </view>
  </block>
</view>
