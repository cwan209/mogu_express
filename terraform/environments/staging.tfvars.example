# Staging 环境变量。复制为 staging.tfvars 并填实际值。
# Workspace: mogu-staging (Terraform Cloud)

env_name      = "staging"
root_domain   = "moguexpress.com"    # 跟 prod 同一根域,只是子域加 -staging
region        = "ap-hongkong"
tencent_intl  = true                  # 腾讯云国际版账号

# Cloudflare(zone_id 在 dashboard 域名 overview 页右下角)
cloudflare_zone_id = "83d7ed862c332ac3b8b23b5b2b0507cc"
# cloudflare_api_token 走 env TF_VAR_cloudflare_api_token,不写进 tfvars

# HK_EXCLUSIVE 2C2G / 40GB SSD(staging 最小档,HK 没有 1C2G Linux 选项)
lighthouse_bundle_id    = "bundle_excl_hk_lin_med2_01"
lighthouse_blueprint_id = "lhbp-qnuz61zs"   # Ubuntu Server 22.04 LTS

# 跟 prod 共用同一对 SSH key 即可
ssh_public_key = "ssh-ed25519 AAAA... mogu-deploy"

cos_bucket_basename = "mogu-express-images"
cos_region          = "ap-hongkong"

# TencentDB Mongo
mongo_memory            = 2                # staging 也 3 节点保持架构一致;省钱可调成 1 (单点版需要换 machine_type,先保持一致)
mongo_volume            = 25
mongo_node_num          = 3
mongo_availability_zone = "ap-hongkong-2"
