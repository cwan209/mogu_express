# 复制为 prod.tfvars 并填实际值。.gitignore 已忽略 *.tfvars。
# 敏感字段(secret_id/key)优先走环境变量 TF_VAR_xxx 或 Terraform Cloud workspace vars。

root_domain    = "mogu-express.com"
region         = "ap-hongkong"

lighthouse_instance_name = "mogu-express-prod"
lighthouse_bundle_id     = "bundle_starter_lin_2c4g80g_h_intl"
lighthouse_blueprint_id  = "lhbp-fdtbngta"

# 从 ssh-keygen -t ed25519 -C 'mogu-deploy' 生成,公钥粘贴在这,私钥放 GH secret SSH_DEPLOY_KEY
ssh_public_key = "ssh-ed25519 AAAA... mogu-deploy"

cos_bucket_basename = "mogu-express-images"
cos_region          = "ap-hongkong"
