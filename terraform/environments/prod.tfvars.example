# Prod 环境变量。复制为 prod.tfvars 并填实际值。
# Workspace: mogu-prod (Terraform Cloud)

env_name      = "prod"
root_domain   = "mogu-express.com"
region        = "ap-hongkong"
tencent_intl  = true                  # 腾讯云国际版账号

# Cloudflare(zone_id 在 dashboard 域名 overview 页右下角)
cloudflare_zone_id = "REPLACE_WITH_ZONE_ID"
# cloudflare_api_token 走 env TF_VAR_cloudflare_api_token,不写进 tfvars

# 2C4G HK 套餐(prod 用大点的)
lighthouse_bundle_id    = "bundle_starter_lin_2c4g80g_h_intl"
lighthouse_blueprint_id = "lhbp-fdtbngta"   # Ubuntu 22.04 LTS HK

# SSH 公钥(对应 GH secret SSH_DEPLOY_KEY 的私钥)
ssh_public_key = "ssh-ed25519 AAAA... mogu-deploy"

cos_bucket_basename = "mogu-express-images"
cos_region          = "ap-hongkong"

# TencentDB Mongo
mongo_memory            = 2                # prod 副本集 1C2G 起,可调
mongo_volume            = 25
mongo_node_num          = 3                # 3 节点副本集
mongo_availability_zone = "ap-hongkong-2"
