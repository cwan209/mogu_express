# 生产 / Staging 部署环境变量模板
#
# 三个环境的来源:
#   local      — 本地 `local-backend/docker-compose.yml` 内嵌默认值,无需 .env
#   staging    — 通过 GH secret `APP_ENV_STAGING`(base64 编码本文件)注入 VPS
#   prod       — 通过 GH secret `APP_ENV_PROD`(base64 编码本文件)注入 VPS
#
# 用法(手动部署兜底):cp .env.example .env && 填实际值
# 自动化:deploy-app.yml 直接渲染,不需手动 cp
#
# 不要把实际填好的 .env 提交进 git

# === 环境标识 ===
# local / staging / prod
ENV_NAME=prod

# === 域名(由 deploy-app workflow 动态填,这里只是兜底)===
SHOP_DOMAIN=shop.your-domain.com
ADMIN_DOMAIN=admin.your-domain.com
API_DOMAIN=api.your-domain.com

# === Let's Encrypt 续期通知 ===
CADDY_EMAIL=you@example.com

# === JWT 签名密钥(用 `openssl rand -hex 32` 生成,staging/prod 必须不同)===
JWT_SECRET=REPLACE_ME_WITH_32_HEX_CHARS

# === 对象存储(staging/prod COS bucket 不同,由 Terraform 输出动态填)===
MINIO_ROOT_USER=mogu_admin
MINIO_ROOT_PASSWORD=REPLACE_ME

S3_ENDPOINT=https://cos.ap-hongkong.myqcloud.com
S3_REGION=ap-hongkong
S3_BUCKET=mogu-express-images-prod-xxxx
S3_ACCESS_KEY=AKIDxxxx
S3_SECRET_KEY=xxxx
S3_PUBLIC_URL=https://mogu-express-images-prod-xxxx.cos.ap-hongkong.myqcloud.com
S3_FORCE_PATH_STYLE=false

# === OTP 短信(staging 建议保持 STUB,prod 才接真实)===
SMS_STUB=0
TENCENT_SMS_SECRET_ID=AKIDxxxx
TENCENT_SMS_SECRET_KEY=xxxx
TENCENT_SMS_APP_ID=1400000000
TENCENT_SMS_SIGN=蘑菇接龙
TENCENT_SMS_TEMPLATE_OTP=1234567
TENCENT_SMS_REGION=ap-guangzhou

# === HuePay(staging 用 STUB=1,prod 切到真实凭证)===
HUEPAY_STUB=1
HUEPAY_API_BASE=https://api.huepay.com.au
HUEPAY_MERCHANT_ID=xxx
HUEPAY_APP_ID=xxx
HUEPAY_API_KEY=xxx
HUEPAY_SECRET=xxx
HUEPAY_NOTIFY_URL=https://api.your-domain.com/cloud/payCallback

# === 启动行为 ===
# 生产环境必须 0,避免线上团被自动续期
BUMP_EXPIRED_TUANS=0
